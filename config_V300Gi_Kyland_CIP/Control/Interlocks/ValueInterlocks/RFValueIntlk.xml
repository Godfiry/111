<ProcessOnTimeOut type="instance" class="CheckItem">
	<setTriggerCondition type="method">(/Control/PMCExports/InnerDatas/ProcessTheRecipeFlag==1)</setTriggerCondition>			
	<setDurativeTimeSCh type="method">/Control/PMCExports/InnerDatas/MaxProcessTime</setDurativeTimeSCh>
	<!--setAlarmMessage type="method">Process on more than the maximum process time</setAlarmMessage-->
	<setAlarmMessageID type="method">140</setAlarmMessageID>	
	<setAlarmSeverity type="method">1</setAlarmSeverity>
	<addAction type="method">./Action</addAction>
	
	<Action type="instance" class="DefaultGuadAction">
		&RFPowerOff;
		<addActuator type="method">./ProcessTheRecipeOff</addActuator>
		
		<ProcessTheRecipeOff type="instance" class="Actuator">
			<setActuatorCh type="method">/Control/PMCExports/InnerDatas/ProcessTheRecipeFlag</setActuatorCh>
			<setActiveHigh type="method">false</setActiveHigh>
