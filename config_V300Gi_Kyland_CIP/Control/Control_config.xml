<Control>
	&StrRC;
	<Alarm>
		&CommonAlarm;
		&PMAlarm;
		&PressureControllAlarm;
	</Alarm>
	<Tool>
		<SetupTool class="SetupTool" type="instance" alias="">
		</SetupTool>
		
		<!--AlarmTool class="AlarmTool" type="instance" alias="">
		</AlarmTool-->
		
		<RecipeTool class="RecipeTool" type="instance" alias="">
		</RecipeTool>
		<VirtualResetButton class="VirtualResetButton" type="instance" alias="/Control/PMCExports/Controls/VirtualResetButton">
			<!--setOnInterlocks type="method">./OpenInterlocks</setOnInterlocks>
			&ResetInterlock;-->
		</VirtualResetButton>
	</Tool>
	
	<Version class="Version" type="instance" alias="">
		&Version;
		<printSoftwareVersion type="method"></printSoftwareVersion>
		<printConfigVersion type="method"></printConfigVersion>
	</Version>
	<Util>
		<CTCExport class="CTCExport" type="instance" alias="">
			<setExportNode type="method">/Control/PMCExports/</setExportNode>
			<setExportToCTC type="method">/SETUP/Counters/SRFTimer/LifeTime,RFLifeTimeForAligner</setExportToCTC>
		</CTCExport>
			
		<AlarmIDAssigner class="AlarmIDAssigner" type="instance" alias="">
			<setStartID type="method">1</setStartID>
			&AlarmsID;
		</AlarmIDAssigner>	
										
		&Monitor;	
		&AlarmRename;						
		&ValueInterlocks;
		&Counter;
	</Util>
		
	<Operational>			
		<PM type="instance" class="OperationalNMCPMModule" alias="/Control/PMCExports/Controls/PM">
			<setPMType type="method">Poly200mmHSE</setPMType>
			<setFunctionalModel type="method">/Control/Functional/PM</setFunctionalModel>
			
			<S1 type="instance" class="OperationalBoshProcess" alias="">
				<setSlotNumber type="method">1</setSlotNumber>
				<setTheProcessStr type="method">/Control/Functional/PM</setTheProcessStr>
				<setProcessingSpell type="method">Processng</setProcessingSpell>
			</S1>	
				
		</PM>
		<HistoryStepData type="instance" class="HistoryStepData" alias="/Control/PMCExports/Controls/HistoryStepData">
		</HistoryStepData>
	</Operational>	
	
	<Functional>
		&FncPM;
	</Functional>
			
	<Maintenance>
		<MPM type="instance" class="MaintenanceTSVPMModule" alias="/Control/PMCExports/Controls/MPM">
				<setFunctionalModel type="method">/Control/Functional/PM</setFunctionalModel>
				&SetSimulated;	
		</MPM>				
	</Maintenance>		
	<HeartBeat class="HeartBeatMechine" type="instance" alias="">
			<setBeatChannel type="method">/Control/PMCExports/InnerDatas/PMCHeartBeatsDO</setBeatChannel>
			<setBeatInterval type="method">1000</setBeatInterval>
	</HeartBeat>	
</Control>
