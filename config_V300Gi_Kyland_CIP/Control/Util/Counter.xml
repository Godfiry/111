<CounterManager type="instance" class="CounterManager">
	<setSaveInterval type="method">30</setSaveInterval>
	<setFilePath type="method">Counters</setFilePath>
	
	<CounterType>
		<WaferCounter type="instance" class="CounterType">
			<setName type="method">WaferCounter</setName>		
			<setTriggerCondition type="method">(/Control/PMCExports/InnerDatas/ProcessHasWaferFlag==1)</setTriggerCondition>	
			<setTypeIsTime type="method">false</setTypeIsTime>	
		</WaferCounter>
		
		<PinCounter type="instance" class="CounterType">
			<setName type="method">PinCounter</setName>		
			<setTriggerCondition type="method">((/Control/PMCExports/InnerDatas/PinUpDO==1)&amp;&amp;(/Control/PMCExports/InnerDatas/PinDownDO==0))</setTriggerCondition>	
			<setTypeIsTime type="method">false</setTypeIsTime>	
		</PinCounter>
		
		<SRFTimer type="instance" class="CounterType">
			<setName type="method">SRFTimer</setName>		
			<setTriggerCondition type="method">((/Control/PMCExports/Datas/SRFPowerOnDO==1)&amp;&amp;(/Control/PMCExports/Datas/SRFSetpointAO&gt;=5.0))</setTriggerCondition>	
			<setTypeIsTime type="method">true</setTypeIsTime>	
		</SRFTimer>

		<LFTimer type="instance" class="CounterType">
			<setName type="method">LFTimer</setName>		
			<setTriggerCondition type="method">((/Control/PMCExports/Datas/LFPowerOnDO==1)&amp;&amp;
			(/Control/PMCExports/Datas/LFSetpointAO&gt;=5.0))</setTriggerCondition>	
			<setTypeIsTime type="method">true</setTypeIsTime>	
		</LFTimer>
		
		<TMPTimer type="instance" class="CounterType">
			<setName type="method">TMPTimer</setName>		
			<setTriggerCondition type="method">(/Control/PMCExports/Datas/TMPAtSpeedDI==1)</setTriggerCondition>	
			<setTypeIsTime type="method">true</setTypeIsTime>	
		</TMPTimer>
		
		<ESCTimer type="instance" class="CounterType">
			<setName type="method">ESCTimer</setName>		
			<setTriggerCondition type="method">(/Control/PMCExports/InnerDatas/ESCHVEnableDO==1)</setTriggerCondition>	
			<setTypeIsTime type="method">true</setTypeIsTime>	
		</ESCTimer>
		
		<Time type="instance" class="CounterType">
			<setName type="method">Time</setName>		
				
			<setTypeIsTime type="method">true</setTypeIsTime>	
		</Time>
	</CounterType>
	
	<CounterItems>
		<WaferCounter type="instance" class="LifeCounter">
			<setPrefix type="method">/SETUP/Counters/WaferCounter/</setPrefix>
			<setHardTolAlmLevel type="method">ERROR</setHardTolAlmLevel>
		</WaferCounter>
		
		<SRFTimer type="instance" class="LifeCounter">
