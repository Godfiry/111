<ATMPressureSwitch type="instance" class="PressureSwitchGaugeMechanism">
	<setID type="method">ATMSwitch</setID>
	<!--setReferenceGauge type="method">../ChamberGaugeSource/GaugeMechanism</setReferenceGauge-->	
	<setAtmosphereSensor type="method">./AtmSensor</setAtmosphereSensor>
	<!--setBelowAtmSensor type="method">./BelowAtmSensor</setBelowAtmSensor-->
	<setVacuumSensor type="method">./VacSensor</setVacuumSensor>
	<!--setAtmosphereValue type="method">735</setAtmosphereValue-->
	<!--setVacuumValue type="method">80</setVacuumValue-->
	
	<AtmSensor type="instance" class="Sensor">
		<setSensorCh type="method">/Control/PMCExports/Datas/ATMSwitchDI</setSensorCh>
		<setActiveHigh type="method">false</setActiveHigh>
		<!--setExportName type="method">dTRC/ATMSns</setExportName-->
	</AtmSensor>

	<VacSensor type="instance" class="Sensor">
		<setSensorCh type="method">/Control/PMCExports/Datas/ATMSwitchDI</setSensorCh>
		<!--setExportName type="method">dTRC/VACSns</setExportName-->
	</VacSensor>
	
	&SetSimulated;
</ATMPressureSwitch>

