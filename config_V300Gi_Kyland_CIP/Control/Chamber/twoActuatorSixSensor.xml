	</OpenOffSense2>	

	<CloseOnSense2 type="instance" class="IOSensorState">
		<setSensor type="method">../../ClosedSensor2</setSensor>
		<setSensorState type="method">true</setSensorState>
	</CloseOnSense2>
	
	<OpenOffSense3 type="instance" class="IOSensorState">
		<setSensor type="method">../../OpenedSensor3</setSensor>
		<setSensorState type="method">false</setSensorState>
	</OpenOffSense3>	

	<CloseOnSense3 type="instance" class="IOSensorState">
		<setSensor type="method">../../ClosedSensor3</setSensor>
		<setSensorState type="method">true</setSensorState>
	</CloseOnSense3>
	
	&SetSimulated;
</Close>
