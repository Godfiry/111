<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE IAP [
<!ENTITY SetSimulated SYSTEM "./SetSimulated.xml">
<!ENTITY SetNotSimulated SYSTEM "./SetNotSimulated.xml">
]>
<Driver>

	<EtherCatPLC type="instance" class="EtherCatPLC_V300Gi">
		&SetSimulated;
		<setNodeNum type="method">200</setNodeNum>
		<setEtherCatDeviceTotalNum type="method">1</setEtherCatDeviceTotalNum>
		<!-- Mac pdo sort -->
		<setMacMapComment comment="deciveMac,deviceMapindex,IOChSize,Inputbyte,outputbyte,simulate"></setMacMapComment>
		<!--MacID,DeviceMapIndex,ChannelSize,Input.ByteSize,Output.ByteSize,Simulation-->
		<setMacMap type="method" >256,1,10000,1402,1400,&PLCSimulated;</setMacMap>
		<setChannelSize type="method">500</setChannelSize>
		<setPollIntervalMS type="method">2</setPollIntervalMS>
	
		<addDeviceDO type="method" comment="channel = start+2">400,1,1,1,1</addDeviceDO>  <!--  SRF off  -->
	    <addDeviceDO type="method" comment="channel = start+2">698,1,1,1,1</addDeviceDO>  <!--  LF off  -->
	
		<addDeviceAI type="method" comment="channel = start+0">402,4,9,0,1,1</addDeviceAI> <!--SRF power-->	
	    <addDeviceAI type="method" comment="channel = start+0">714,4,9,0,1,1</addDeviceAI> <!--LF power-->	
	
	</EtherCatPLC>
	
