<OpenInterlocks type="instance" class="IOInterlocks">
	<setAlarmMessage type="method">Can't ring down</setAlarmMessage>
	<addToIOInterlocks type="method">./ChamberCDANotOK</addToIOInterlocks>
	<addToIOInterlocks type="method">./Pin1NotDown</addToIOInterlocks>
	<addToIOInterlocks type="method">./Pin2NotDown</addToIOInterlocks>
	<addToIOInterlocks type="method">./Pin3NotDown</addToIOInterlocks>	
	<addToIOInterlocks type="method">./PinIsUP</addToIOInterlocks>
	<!--addToIOInterlocks type="method">./PMNOWfr</addToIOInterlocks-->		
	
	<ChamberCDANotOK type="instance" class="IOInterlockCondition">	
		<setMessageID type="method">298</setMessageID>
		<setConditionStr type="method">(/Control/PMCExports/InnerDatas/GasboxCDADI==1)</setConditionStr>
	</ChamberCDANotOK>
	<Pin1NotDown type="instance" class="IOInterlockCondition">	
		<setMessageID type="method">299</setMessageID>
		<setConditionStr type="method">(/Control/PMCExports/InnerDatas/Pin1DownDI==1)</setConditionStr>
	</Pin1NotDown>
	<Pin2NotDown type="instance" class="IOInterlockCondition">	
		<setMessageID type="method">299</setMessageID>
		<setConditionStr type="method">(/Control/PMCExports/InnerDatas/Pin2DownDI==1)</setConditionStr>
	</Pin2NotDown>
	<Pin3NotDown type="instance" class="IOInterlockCondition">	
		<setMessageID type="method">299</setMessageID>
		<setConditionStr type="method">(/Control/PMCExports/InnerDatas/Pin3DownDI==1)</setConditionStr>
	</Pin3NotDown>
	<PinIsUP type="instance" class="IOInterlockCondition">	
		<setMessageID type="method">300</setMessageID>
		<setConditionStr type="method">(/Control/PMCExports/InnerDatas/PinUpDO==0)</setConditionStr>
	</PinIsUP>
	&SetSimulated;
</OpenInterlocks>

<CloseInterlocks type="instance" class="IOInterlocks">
	<setAlarmMessage type="method">Can't ring up</setAlarmMessage>
	<addToIOInterlocks type="method">./ChamberCDANotOK</addToIOInterlocks>	
	<addToIOInterlocks type="method">./ChamberSWOpen</addToIOInterlocks>
	
	<ChamberCDANotOK type="instance" class="IOInterlockCondition">	
		<setMessageID type="method">302</setMessageID>
		<setConditionStr type="method">(/Control/PMCExports/InnerDatas/GasboxCDADI==1)</setConditionStr>
	</ChamberCDANotOK>
	
	<ChamberSWOpen type="instance" class="IOInterlockCondition">	
		<setMessageID type="method">303</setMessageID>
		<setConditionStr type="method">((/Control/PMCExports/InnerDatas/ChamberSW1DI==1)&amp;&amp;(/Control/PMCExports/InnerDatas/ChamberSW2DI==1))</setConditionStr>
	</ChamberSWOpen>	
	
	<HeRFCoverSWUnConnect type="instance" class="IOInterlockCondition">	
		<setMessageID type="method">304</setMessageID>
		<setConditionStr type="method">(/Control/PMCExports/Datas/HeRFCoverSWDI==1)</setConditionStr>
	</HeRFCoverSWUnConnect>
		
	&SetSimulated;
</CloseInterlocks>
