<SRFPower type="instance" class="ProcessCheckItem">
	<setSetPointID type="method">SRFPower(W)</setSetPointID>	
	<setCheckDelaySCh type="method">/SETUP/RF/cfgSRFToleranceCheckDelay</setCheckDelaySCh>	
	<!--setAlarmMessage type="method">SRF power exceeded soft tolerance</setAlarmMessage-->
	<setAlarmMessageID type="method">91</setAlarmMessageID>	
	<setSensor type="method">/Control/PMCExports/Datas/SRF_ForwardPower</setSensor>
	<setTolerance type="method">/SETUP/Recipe/cfgSRFPowerSoftTol</setTolerance>		
	<setZeroTolerance type="method">5</setZeroTolerance>
	<setDurativeTimeSCh type="method">/SETUP/RF/cfgSRFSoftToleranceTimeout</setDurativeTimeSCh>	
	<setNextCheckItem type="method">./CheckHardTolerance</setNextCheckItem>	
	
	<CheckHardTolerance type="instance" class="ProcessCheckItem">
		<setCheckDelaySCh type="method">/SETUP/RF/cfgSRFToleranceCheckDelay</setCheckDelaySCh>		
		<!--setAlarmMessage type="method">SRF power exceeded hard tolerance</setAlarmMessage-->
		<setAlarmMessageID type="method">92</setAlarmMessageID>	
		<setAlarmSeverity type="method">1</setAlarmSeverity>
		<setSensor type="method">/Control/PMCExports/Datas/SRF_ForwardPower</setSensor>
		<setTolerance type="method">/SETUP/Recipe/cfgSRFPowerHardTol</setTolerance>
		<setZeroTolerance type="method">6</setZeroTolerance>
		<setDurativeTimeSCh type="method">/SETUP/RF/cfgSRFHardToleranceTimeout</setDurativeTimeSCh>	
	</CheckHardTolerance>		
</SRFPower>

