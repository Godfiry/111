<ChamberGaugeSource  type="instance" class="GaugeSource">
	<setGaugeMechanism type="method">./GaugeMechanism</setGaugeMechanism>
	<setLowerLimit type="method">-1</setLowerLimit>
	<setUpperLimit type="method">10</setUpperLimit>	
	<addGaugeMechanism type="method">../ForlineGaugeSource/GaugeMechanism</addGaugeMechanism>
	<addGaugeMechanism type="method">../ATMPressureSwitch</addGaugeMechanism>
	<addGaugeMechanism type="method">../VACPressureSwitch</addGaugeMechanism>
	<addGaugeMechanism type="method">../Pressure100mTSwitch</addGaugeMechanism>
	<addGaugeMechanism type="method">../Pressure500mTSwitch</addGaugeMechanism>
	<addGaugeMechanism type="method">../ForlinePressureSwitch</addGaugeMechanism>
	<addGaugeMechanism type="method">../ProcessGaugeSource/GaugeMechanism</addGaugeMechanism>
	<setNextGauge type="method">../ProcessGaugeSource</setNextGauge>
	<!--setPreviousGauge type="method">./GaugeSource</setPreviousGauge-->
	<!--setHighAccuracyGauge type="method">true</setHighAccuracyGauge-->
	
	<GaugeMechanism type="instance" class="GaugeMechanism">
		<setID type="method">Chamber</setID>
		<!--setGaugeDriver type="method"></setGaugeDriver-->		
		<setPressureChannel type="method">/Control/PMCExports/Datas/ChamberPressure</setPressureChannel>		
		&SetSimulated;
	</GaugeMechanism>
</ChamberGaugeSource>

<ProcessGaugeSource  type="instance" class="GaugeSource">
	<setGaugeMechanism type="method">./GaugeMechanism</setGaugeMechanism>
	<setLowerLimit type="method">-1</setLowerLimit>
	<setUpperLimit type="method">0.249</setUpperLimit>	
	<setHighAccuracyGauge type="method">true</setHighAccuracyGauge>
	<setUnit type="method" comment="1:Torr 2:mTorr">2</setUnit>
	<setPreviousGauge type="method">../ChamberGaugeSource</setPreviousGauge>
	<!--setNextGauge type="method">./</setNextGauge-->

	<GaugeMechanism type="instance" class="GaugeMechanism">
		<setID type="method">Process</setID>
		<!--setGaugeDriver type="method"></setGaugeDriver-->		
		<setPressureChannel type="method">/Control/PMCExports/Datas/ProcessPressure</setPressureChannel>	
		&SetSimulated;
	</GaugeMechanism>
</ProcessGaugeSource>

<ForlineGaugeSource  type="instance" class="GaugeSource">
	<setGaugeMechanism type="method">./GaugeMechanism</setGaugeMechanism>
	<setLowerLimit type="method">-1</setLowerLimit>
	<setUpperLimit type="method">10</setUpperLimit>
	<!--setPreviousGauge type="method"></setPreviousGauge-->
	<!--setHighAccuracyGauge type="method">true</setHighAccuracyGauge-->
	<!--setNextGauge type="method">./</setNextGauge-->

	<GaugeMechanism type="instance" class="GaugeMechanism">
		<setID type="method">Forline</setID>
