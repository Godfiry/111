<SRFReflPower type="instance" class="DualProcessCheckItem">
	<setSetPointID type="method">SRFMaxReflectedPower(W)</setSetPointID>	
	<setCheckDelaySCh type="method">/SETUP/RF/cfgSRFReflCheckDelay</setCheckDelaySCh>	
	<!--setAlarmMessage type="method">SRF reflected power exceeded max value</setAlarmMessage-->
	<setAlarmMessageID type="method">87</setAlarmMessageID>	
	<setAlarmSeverity type="method">1</setAlarmSeverity>
	<setSensor type="method">/Control/PMCExports/Datas/SRFReflectPWRAI</setSensor>
	<setAlternativeSetPoint type="method">/SETUP/RF/cfgSRFMaxReflectedPower</setAlternativeSetPoint>		
	<setDurativeTimeSCh type="method">/SETUP/RF/cfgSRFReflTimeout</setDurativeTimeSCh>	
	<!--setNextCheckItem type="method">./CheckHardTolerance</setNextCheckItem-->	
</SRFReflPower>	

