<OpenInterlocks type="instance" class="IOInterlocks">
	<setAlarmMessage type="method">Can't set WindowsInner Temp</setAlarmMessage>
	<addToIOInterlocks type="method">./AirFlowAbnormal</addToIOInterlocks>
	
	<AirFlowAbnormal type="instance" class="IOInterlockCondition">
		<setMessageID type="method">312</setMessageID>
		<setConditionStr type="method">(/Control/PMCExports/InnerDatas/AirFlowOrTopOTSWDI==1)</setConditionStr>
	</AirFlowAbnormal>	
	
	&SetSimulated;
</OpenInterlocks>

<CloseInterlocks type="instance" class="IOInterlocks">
	<!--addToIOInterlocks type="method"></addToIOInterlocks-->
	&SetSimulated;
</CloseInterlocks>
